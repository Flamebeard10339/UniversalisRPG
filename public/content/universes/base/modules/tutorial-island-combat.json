          {
            "op": "add",
            "path": "/actions/-",
            "value": {
              "id": "continue",
              "instant": true,
              "rewards": [],
              "results": [
                {
                  "kind": "relocate",
                  "locationId": "tutorial-rat-cage"
                }
              ]
            }
          }
        ]
      }
    ]
  },
