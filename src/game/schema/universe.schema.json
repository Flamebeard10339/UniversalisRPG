{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://universalis-rpg.local/schema/universe.schema.json",
  "type": "object",
  "required": ["schemaVersion", "id", "version", "author", "locales", "files"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "author": { "type": "string", "minLength": 1 },
    "locales": {
      "type": "array",
      "items": { "type": "string", "minLength": 2 },
      "minItems": 1,
      "uniqueItems": true
    },
    "files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "basePlayer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inventory": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 }
        }
      }
    },
    "combatBalance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expectedHitsToKill", "combatSpread"],
      "properties": {
        "expectedHitsToKill": { "type": "number", "exclusiveMinimum": 0 },
        "combatSpread": { "type": "number", "minimum": 0 }
      }
    },
    "displayProfiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "titleKey": { "type": "string", "minLength": 1 },
          "colors": { "$ref": "#/$defs/displayPalette" },
          "light": { "$ref": "#/$defs/displayPalette" },
          "dark": { "$ref": "#/$defs/displayPalette" }
        }
      },
      "uniqueItems": true
    },
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "floatingTextDurationSeconds": { "type": "number", "exclusiveMinimum": 0 },
        "loopActionsByDefault": { "type": "boolean" }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minAppVersion": { "type": "string" },
        "maxAppVersion": { "type": "string" }
      }
    }
  },
  "$defs": {
    "displayPalette": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "background": { "$ref": "#/$defs/color" },
        "surface": { "$ref": "#/$defs/color" },
        "surfaceRaised": { "$ref": "#/$defs/color" },
        "panel": { "$ref": "#/$defs/color" },
        "border": { "$ref": "#/$defs/color" },
        "text": { "$ref": "#/$defs/color" },
        "textMuted": { "$ref": "#/$defs/color" },
        "textSubtle": { "$ref": "#/$defs/color" },
        "accent": { "$ref": "#/$defs/color" },
        "accentStrong": { "$ref": "#/$defs/color" },
        "accentText": { "$ref": "#/$defs/color" },
        "danger": { "$ref": "#/$defs/color" },
        "dangerSurface": { "$ref": "#/$defs/color" },
        "dangerText": { "$ref": "#/$defs/color" },
        "success": { "$ref": "#/$defs/color" },
        "warning": { "$ref": "#/$defs/color" }
      }
    },
    "color": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    }
  }
}
