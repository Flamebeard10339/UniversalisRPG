{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://universalis-rpg.local/schema/universe.schema.json",
  "type": "object",
  "required": ["schemaVersion", "id", "version", "author", "locales", "files"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "author": { "type": "string", "minLength": 1 },
    "locales": {
      "type": "array",
      "items": { "type": "string", "minLength": 2 },
      "minItems": 1,
      "uniqueItems": true
    },
    "files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "basePlayer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stats": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "inventory": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 }
        }
      }
    },
    "combatBalance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expectedHitsToKill", "combatSpread"],
      "properties": {
        "expectedHitsToKill": { "type": "number", "exclusiveMinimum": 0 },
        "combatSpread": { "type": "number", "minimum": 0 }
      }
    },
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "floatingTextDurationSeconds": { "type": "number", "exclusiveMinimum": 0 },
        "loopActionsByDefault": { "type": "boolean" }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minAppVersion": { "type": "string" },
        "maxAppVersion": { "type": "string" }
      }
    }
  }
}
