{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://universalis-rpg.local/schema/universe.schema.json",
  "type": "object",
  "required": ["schemaVersion", "id", "titleKey", "version", "author", "locales", "files"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "minLength": 1 },
    "titleKey": { "type": "string", "minLength": 1 },
    "descriptionKey": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "author": { "type": "string", "minLength": 1 },
    "locales": {
      "type": "array",
      "items": { "type": "string", "minLength": 2 },
      "minItems": 1,
      "uniqueItems": true
    },
    "files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minAppVersion": { "type": "string" },
        "maxAppVersion": { "type": "string" }
      }
    },
    "deathReset": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "locationId": { "type": "string", "minLength": 1 },
        "preserve": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "inventoryIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
            "resourceIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
            "flagIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
            "skillXp": { "type": "boolean" },
            "discoveredLocations": { "type": "boolean" },
            "actionCompletionIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
          }
        }
      }
    }
  }
}
