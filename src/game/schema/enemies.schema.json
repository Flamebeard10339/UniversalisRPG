{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://universalis-rpg.local/schema/enemies.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "interactionTypeId", "rewards"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "interactionTypeId": { "type": "string", "minLength": 1 },
      "stats": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "attack": { "type": "number", "exclusiveMinimum": 0 },
          "defense": { "type": "number", "minimum": 0 },
          "health": { "type": "number", "exclusiveMinimum": 0 },
          "rate": { "type": "number", "minimum": 0 },
          "regeneration": { "type": "number", "minimum": 0 },
          "armorPenetration": { "type": "number", "minimum": 0 },
          "torpidity": { "type": "number", "minimum": 0 },
          "critChance": { "type": "number", "minimum": 0, "maximum": 100 },
          "critMultiplier": { "type": "number", "minimum": 1 }
        }
      },
      "attack": { "type": "number", "exclusiveMinimum": 0 },
      "defense": { "type": "number", "minimum": 0 },
      "health": { "type": "number", "exclusiveMinimum": 0 },
      "rate": { "type": "number", "minimum": 0 },
      "regeneration": { "type": "number", "minimum": 0 },
      "armorPenetration": { "type": "number", "minimum": 0 },
      "torpidity": { "type": "number", "minimum": 0 },
      "critChance": { "type": "number", "minimum": 0, "maximum": 100 },
      "critMultiplier": { "type": "number", "minimum": 1 },
      "showHealthBar": { "type": "boolean" },
      "rewards": {
        "type": "array",
        "items": {
          "oneOf": [
            {
              "type": "object",
              "required": ["kind", "skillId", "amount"],
              "additionalProperties": false,
              "properties": {
                "kind": { "const": "skillXp" },
                "skillId": { "type": "string", "minLength": 1 },
                "amount": { "type": "number", "exclusiveMinimum": 0 }
              }
            },
            {
              "type": "object",
              "required": ["kind", "resourceId", "amount"],
              "additionalProperties": false,
              "properties": {
                "kind": { "const": "resource" },
                "resourceId": { "type": "string", "minLength": 1 },
                "amount": { "type": "number", "exclusiveMinimum": 0 }
              }
            }
          ]
        }
      }
    }
  }
}
