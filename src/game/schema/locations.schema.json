{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://universalis-rpg.local/schema/locations.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "position"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "position": {
        "type": "object",
        "required": ["x", "y"],
        "additionalProperties": false,
        "properties": {
          "x": { "type": "number" },
          "y": { "type": "number" }
        }
      },
      "starting": { "type": "boolean" },
      "tags": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 },
        "uniqueItems": true
      },
      "entities": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 },
        "uniqueItems": true
      }
    }
  }
}
