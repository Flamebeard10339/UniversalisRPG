{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://universalis-rpg.local/schema/interaction-types.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "sourceStatId", "targetStatId", "targetPlayerHealth"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "sourceStatId": { "type": "string", "minLength": 1 },
      "targetStatId": { "type": "string", "minLength": 1 },
      "targetPlayerHealth": { "type": "boolean" },
      "experience": {
        "type": "array",
        "items": { "$ref": "https://universalis-rpg.local/schema/actions.schema.json#/$defs/experienceTrigger" }
      }
    }
  }
}
