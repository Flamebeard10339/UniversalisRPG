{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://universalis-rpg.local/schema/recipes.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "stationId", "inputs", "outputs"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "stationId": { "type": "string", "minLength": 1 },
      "skillId": { "type": "string", "minLength": 1 },
      "xpAmount": { "type": "number" },
      "durationSeconds": { "type": "number", "exclusiveMinimum": 0 },
      "resultMessageKey": { "type": "string", "minLength": 1 },
      "extraResults": {
        "type": "array",
        "items": { "$ref": "https://universalis-rpg.local/schema/actions.schema.json#/$defs/result" }
      },
      "inputs": {
        "type": "array",
        "minItems": 1,
        "items": { "$ref": "#/$defs/ingredient" }
      },
      "outputs": {
        "type": "array",
        "minItems": 1,
        "items": { "$ref": "#/$defs/ingredient" }
      }
    }
  },
  "$defs": {
    "ingredient": {
      "type": "object",
      "required": ["itemId", "amount"],
      "additionalProperties": false,
      "properties": {
        "itemId": { "type": "string", "minLength": 1 },
        "amount": { "type": "number", "exclusiveMinimum": 0 }
      }
    }
  }
}
