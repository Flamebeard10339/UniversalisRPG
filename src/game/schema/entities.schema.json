{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://universalis-rpg.local/schema/entities.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "actionIds": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 },
        "uniqueItems": true
      },
      "actions": {
        "type": "array",
        "items": { "$ref": "#/$defs/action" }
      },
      "collectionLog": {
        "type": "array",
        "items": { "$ref": "#/$defs/collectionLog" }
      }
    }
  },
  "$defs": {
    "collectionLog": {
      "type": "object",
      "required": ["categoryId", "actionId"],
      "additionalProperties": false,
      "properties": {
        "categoryId": { "type": "string", "minLength": 1 },
        "actionId": { "type": "string", "minLength": 1 },
        "killTargetCount": { "type": "integer", "minimum": 1 },
        "dropTableIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "itemIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "action": {
      "type": "object",
      "required": ["id", "durationSeconds", "rewards"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "durationSeconds": { "type": "number", "exclusiveMinimum": 0 },
        "rewards": { "type": "array" },
        "interactionTypeId": { "type": "string", "minLength": 1 },
        "enemy": { "type": "object" }
      }
    }
  }
}
