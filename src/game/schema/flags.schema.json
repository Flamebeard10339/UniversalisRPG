{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://universalis-rpg.local/schema/flags.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "initialValue": { "type": ["boolean", "number", "string"] }
    }
  }
}
