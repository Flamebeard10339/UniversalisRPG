{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://universalis-rpg.local/schema/dialogues.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "startNodeId", "nodes"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "startNodeId": { "type": "string", "minLength": 1 },
      "nodes": {
        "type": "array",
        "items": { "$ref": "#/$defs/node" }
      }
    }
  },
  "$defs": {
    "comparison": {
      "enum": ["equal", "greater-than", "less-than"]
    },
    "condition": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "variable", "comparison", "value"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "state-variable" },
            "variable": { "type": "string", "minLength": 1 },
            "comparison": { "$ref": "#/$defs/comparison" },
            "value": { "type": ["number", "boolean", "string"] }
          }
        },
        {
          "type": "object",
          "required": ["kind", "conditions"],
          "additionalProperties": false,
          "properties": {
            "kind": { "enum": ["all", "any"] },
            "conditions": { "type": "array", "items": { "$ref": "#/$defs/condition" } }
          }
        },
        {
          "type": "object",
          "required": ["kind", "condition"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "not" },
            "condition": { "$ref": "#/$defs/condition" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "tag"],
          "additionalProperties": false,
          "properties": {
            "kind": { "enum": ["item-tag", "equipped-item-tag"] },
            "tag": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "result": {
      "oneOf": [
        { "type": "object", "required": ["kind", "itemId", "amount"], "additionalProperties": false, "properties": { "kind": { "const": "item" }, "itemId": { "type": "string", "minLength": 1 }, "amount": { "type": "number", "not": { "const": 0 } } } },
        { "type": "object", "required": ["kind", "resourceId", "amount"], "additionalProperties": false, "properties": { "kind": { "const": "resource" }, "resourceId": { "type": "string", "minLength": 1 }, "amount": { "type": "number", "not": { "const": 0 } } } },
        { "type": "object", "required": ["kind", "skillId", "amount"], "additionalProperties": false, "properties": { "kind": { "const": "skill-xp" }, "skillId": { "type": "string", "minLength": 1 }, "amount": { "type": "number", "not": { "const": 0 } } } },
        { "type": "object", "required": ["kind", "variable", "value"], "additionalProperties": false, "properties": { "kind": { "const": "state-variable" }, "variable": { "type": "string", "minLength": 1 }, "value": { "type": ["boolean", "number", "string"] } } },
        { "type": "object", "required": ["kind", "variable", "amount"], "additionalProperties": false, "properties": { "kind": { "const": "state-variable-delta" }, "variable": { "type": "string", "minLength": 1 }, "amount": { "type": "number", "not": { "const": 0 } } } },
        { "type": "object", "required": ["kind", "flagId", "value"], "additionalProperties": false, "properties": { "kind": { "const": "flag" }, "flagId": { "type": "string", "minLength": 1 }, "value": { "type": "boolean" } } },
        { "type": "object", "required": ["kind", "locationId"], "additionalProperties": false, "properties": { "kind": { "const": "relocate" }, "locationId": { "type": "string", "minLength": 1 } } },
        { "type": "object", "required": ["kind", "dialogueId"], "additionalProperties": false, "properties": { "kind": { "const": "dialogue" }, "dialogueId": { "type": "string", "minLength": 1 } } },
        { "type": "object", "required": ["kind", "messageKey"], "additionalProperties": false, "properties": { "kind": { "const": "chat" }, "messageKey": { "type": "string", "minLength": 1 }, "delaySeconds": { "type": "number", "minimum": 0, "maximum": 2 } } }
      ]
    },
    "option": {
      "type": "object",
      "required": ["id", "labelKey"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "labelKey": { "type": "string", "minLength": 1 },
        "conditions": { "$ref": "#/$defs/condition" },
        "results": { "type": "array", "items": { "$ref": "#/$defs/result" } },
        "gotoNodeId": { "type": "string", "minLength": 1 }
      }
    },
    "branch": {
      "type": "object",
      "required": ["conditions", "gotoNodeId"],
      "additionalProperties": false,
      "properties": {
        "conditions": { "$ref": "#/$defs/condition" },
        "gotoNodeId": { "type": "string", "minLength": 1 }
      }
    },
    "node": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "speakerId": { "type": "string", "minLength": 1 },
        "textKey": { "type": "string", "minLength": 1 },
        "narratorKey": { "type": "string", "minLength": 1 },
        "results": { "type": "array", "items": { "$ref": "#/$defs/result" } },
        "branches": { "type": "array", "items": { "$ref": "#/$defs/branch" } },
        "gotoNodeId": { "type": "string", "minLength": 1 },
        "options": { "type": "array", "items": { "$ref": "#/$defs/option" } }
      }
    }
  }
}
