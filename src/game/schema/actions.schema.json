{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://universalis-rpg.local/schema/actions.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "locationId", "durationSeconds", "rewards"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "locationId": { "type": "string", "minLength": 1 },
      "role": { "enum": ["optional", "progression", "utility"] },
      "durationSeconds": { "type": "number", "exclusiveMinimum": 0 },
      "maxCompletions": { "type": "integer", "minimum": 1 },
      "enemyId": { "type": "string", "minLength": 1 },
      "interactionTypeId": { "type": "string", "minLength": 1 },
      "rewards": {
        "type": "array",
        "items": { "$ref": "#/$defs/reward" }
      },
      "experience": {
        "type": "array",
        "items": { "$ref": "#/$defs/experienceTrigger" }
      },
      "results": {
        "type": "array",
        "items": { "$ref": "#/$defs/result" }
      },
      "visibleWhen": { "$ref": "#/$defs/condition" },
      "requirements": { "$ref": "#/$defs/condition" }
    }
  },
  "$defs": {
    "comparison": {
      "enum": ["equal", "greater-than", "less-than"]
    },
    "condition": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "variable", "comparison", "value"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "state-variable" },
            "variable": { "type": "string", "minLength": 1 },
            "comparison": { "$ref": "#/$defs/comparison" },
            "value": { "type": ["number", "boolean", "string"] }
          }
        },
        {
          "type": "object",
          "required": ["kind", "conditions"],
          "additionalProperties": false,
          "properties": {
            "kind": { "enum": ["all", "any"] },
            "conditions": { "type": "array", "items": { "$ref": "#/$defs/condition" } }
          }
        },
        {
          "type": "object",
          "required": ["kind", "condition"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "not" },
            "condition": { "$ref": "#/$defs/condition" }
          }
        }
      ]
    },
    "reward": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "skillId", "amount"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "skillXp" },
            "skillId": { "type": "string", "minLength": 1 },
            "amount": { "type": "number", "exclusiveMinimum": 0 }
          }
        },
        {
          "type": "object",
          "required": ["kind", "resourceId", "amount"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "resource" },
            "resourceId": { "type": "string", "minLength": 1 },
            "amount": { "type": "number", "exclusiveMinimum": 0 }
          }
        },
        {
          "type": "object",
          "required": ["kind", "itemId", "amount"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "item" },
            "itemId": { "type": "string", "minLength": 1 },
            "amount": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      ]
    },
    "experienceTrigger": {
      "type": "object",
      "required": ["event", "skillId"],
      "additionalProperties": false,
      "properties": {
        "event": { "enum": ["action-complete", "damage-dealt", "damage-taken", "health-regenerated", "incoming-attack-missed"] },
        "skillId": { "type": "string", "minLength": 1 },
        "amount": { "type": "number", "exclusiveMinimum": 0 },
        "amountPerUnit": { "type": "number", "exclusiveMinimum": 0 },
        "effectId": { "type": "string", "minLength": 1 },
        "enemyId": { "type": "string", "minLength": 1 },
        "interactionTypeId": { "type": "string", "minLength": 1 },
        "resourceId": { "type": "string", "minLength": 1 },
        "sourceStat": { "type": "string", "minLength": 1 }
      }
    },
    "result": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "itemId", "amount"],
          "additionalProperties": false,
          "properties": { "kind": { "const": "item" }, "itemId": { "type": "string", "minLength": 1 }, "amount": { "type": "number", "not": { "const": 0 } } }
        },
        {
          "type": "object",
          "required": ["kind", "resourceId", "amount"],
          "additionalProperties": false,
          "properties": { "kind": { "const": "resource" }, "resourceId": { "type": "string", "minLength": 1 }, "amount": { "type": "number", "not": { "const": 0 } } }
        },
        {
          "type": "object",
          "required": ["kind", "skillId", "amount"],
          "additionalProperties": false,
          "properties": { "kind": { "const": "skill-xp" }, "skillId": { "type": "string", "minLength": 1 }, "amount": { "type": "number", "not": { "const": 0 } } }
        },
        {
          "type": "object",
          "required": ["kind", "variable", "value"],
          "additionalProperties": false,
          "properties": { "kind": { "const": "state-variable" }, "variable": { "type": "string", "minLength": 1 }, "value": { "type": ["boolean", "number", "string"] } }
        },
        {
          "type": "object",
          "required": ["kind", "variable", "amount"],
          "additionalProperties": false,
          "properties": { "kind": { "const": "state-variable-delta" }, "variable": { "type": "string", "minLength": 1 }, "amount": { "type": "number", "not": { "const": 0 } } }
        },
        {
          "type": "object",
          "required": ["kind", "flagId", "value"],
          "additionalProperties": false,
          "properties": { "kind": { "const": "flag" }, "flagId": { "type": "string", "minLength": 1 }, "value": { "type": "boolean" } }
        },
        {
          "type": "object",
          "required": ["kind", "locationId"],
          "additionalProperties": false,
          "properties": { "kind": { "const": "relocate" }, "locationId": { "type": "string", "minLength": 1 } }
        },
        {
          "type": "object",
          "required": ["kind", "dialogueId"],
          "additionalProperties": false,
          "properties": { "kind": { "const": "dialogue" }, "dialogueId": { "type": "string", "minLength": 1 } }
        },
        {
          "type": "object",
          "required": ["kind", "messageKey"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "chat" },
            "messageKey": { "type": "string", "minLength": 1 },
            "delaySeconds": { "type": "number", "minimum": 0, "maximum": 2 }
          }
        }
      ]
    }
  }
}
