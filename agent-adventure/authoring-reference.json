{
  "manifest": {
    "schemaVersion": 1,
    "id": "universe-id",
    "version": "0.1.0",
    "author": "Author",
    "locales": ["en"],
    "files": [],
    "compatibility": {
      "minAppVersion": "0.1.0"
    }
  },
  "location": {
    "id": "location-id",
    "position": { "x": 0, "y": 0 },
    "starting": false
  },
  "action": {
    "id": "action-id",
    "locationId": "location-id",
    "durationSeconds": 5,
    "maxCompletions": 1,
    "role": "progression",
    "rewards": [],
    "results": [
      { "kind": "chat", "messageKey": "event.next-beat", "delaySeconds": 1 }
    ]
  },
  "item": {
    "id": "item-id",
    "maxQuantity": 1
  },
  "flag": {
    "id": "flag-id",
    "initialValue": false
  },
  "stat": {
    "id": "air-capacity",
    "base": 100,
    "added": 0,
    "increased": 0,
    "skillId": "optional-skill-id"
  },
  "resource": {
    "id": "air-capacity",
    "sourceStat": "air-capacity",
    "initialValue": "full",
    "onEmpty": [
      { "kind": "reset-state", "locationId": "starting-location" }
    ]
  },
  "effect": {
    "id": "air-loss",
    "resourceId": "air-capacity",
    "sourceStat": "air-leak"
  },
  "locationEffect": {
    "id": "poison-gas",
    "resourceId": "health",
    "sourceStat": "poison-gas-damage",
    "locationId": "gas-chamber"
  },
  "condition": {
    "kind": "all",
    "conditions": [
      { "kind": "not", "condition": { "kind": "state-variable", "variable": "item:space-suit", "comparison": "less-than", "value": 1 } },
      { "kind": "state-variable", "variable": "flag:airlock-open", "comparison": "equal", "value": true }
    ]
  }
}
