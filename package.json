{
  "name": "universalis-rpg",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --open --configLoader runner",
    "dev:android": "concurrently \"vite --configLoader runner\" \"wait-on http://localhost:5173 && cap run android --livereload\"",
    "build": "tsc && vite build --configLoader runner",
    "preview": "vite preview --configLoader runner",
    "sync": "npm run build && cap sync",
    "test": "vitest run --configLoader runner",
    "test:ui": "node scripts/ui-smoke.mjs",
    "merge:issue": "node scripts/merge-contribution-issue.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.2.1",
    "@capacitor/preferences": "^6.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "playwright-core": "^1.61.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^6.0.1",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.1"
  }
}
